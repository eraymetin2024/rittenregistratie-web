---
// Officiële-stijl download-knoppen (Google Play + App Store). App Store toont
// "Binnenkort" zolang er nog geen store-URL is (eerlijk, geen dode link).
import { SITE } from '../consts';

const { class: klass = '', center = false, dark = false } = Astro.props;
const playLive = SITE.playUrl && SITE.playUrl !== '#';
const appleLive = SITE.appStoreUrl && SITE.appStoreUrl !== '#';

// Knop-stijl: op donkere hero een witte rand, anders een zwarte badge.
const base =
  'group inline-flex items-center gap-3 rounded-2xl px-4 py-2.5 transition-all duration-200 hover:-translate-y-0.5';
const solid = dark
  ? 'bg-white text-ink hover:shadow-[0_18px_40px_-12px_rgba(255,255,255,0.35)]'
  : 'bg-ink text-white hover:shadow-soft';
---

<div
  class:list={[
    'flex flex-wrap items-center gap-3',
    center ? 'justify-center' : '',
    klass,
  ]}
>
  <!-- Google Play -->
  <a
    href={playLive ? SITE.playUrl : '/download'}
    class:list={[base, solid]}
    aria-label="Download in Google Play"
    {...(playLive ? { target: '_blank', rel: 'noopener' } : {})}
  >
    <svg viewBox="0 0 512 512" class="h-7 w-7 shrink-0" aria-hidden="true">
      <path fill="#00D9FF" d="M48 30v452l244-226z" />
      <path fill="#00F076" d="M48 30l244 226 78-72L92 18C76 9 60 14 48 30z" />
      <path fill="#FF3A44" d="M48 482l244-226 78 72-278 162c-16 9-32 4-44-12z" />
      <path fill="#FFC500" d="M370 184l86 50c22 13 22 31 0 44l-86 50-78-72z" />
    </svg>
    <span class="text-left leading-tight">
      <span class="block text-[10px] font-medium uppercase tracking-wider opacity-70">Ontdek het op</span>
      <span class="block text-[17px] font-bold leading-none">Google Play</span>
    </span>
  </a>

  <!-- App Store -->
  <a
    href={appleLive ? SITE.appStoreUrl : '/download'}
    class:list={[base, solid, appleLive ? '' : 'relative opacity-90']}
    aria-label={appleLive ? 'Download in de App Store' : 'App Store — binnenkort'}
    {...(appleLive ? { target: '_blank', rel: 'noopener' } : {})}
  >
    <svg viewBox="0 0 24 24" class="h-7 w-7 shrink-0" fill="currentColor" aria-hidden="true">
      <path d="M16.4 12.9c0-2.2 1.8-3.3 1.9-3.4-1-1.5-2.6-1.7-3.2-1.7-1.4-.1-2.7.8-3.3.8-.7 0-1.7-.8-2.8-.8-1.4 0-2.8.8-3.5 2.1-1.5 2.6-.4 6.5 1.1 8.6.7 1 1.6 2.2 2.7 2.1 1.1 0 1.5-.7 2.8-.7s1.6.7 2.8.7 1.9-1 2.6-2c.8-1.2 1.2-2.3 1.2-2.4-.1 0-2.3-.9-2.3-3.2zM14.3 6.3c.6-.7 1-1.7.9-2.7-.9 0-1.9.6-2.5 1.3-.6.6-1 1.6-.9 2.6 1 .1 1.9-.5 2.5-1.2z"/>
    </svg>
    <span class="text-left leading-tight">
      <span class="block text-[10px] font-medium uppercase tracking-wider opacity-70">
        {appleLive ? 'Download in de' : 'Binnenkort in de'}
      </span>
      <span class="block text-[17px] font-bold leading-none">App Store</span>
    </span>
  </a>
</div>

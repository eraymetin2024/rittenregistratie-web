---
import { NAV, SITE } from '../consts';
import Logo from './Logo.astro';
const pad = Astro.url.pathname;
---
<!-- Slanke top-bar -->
<div class="bg-ink text-white">
  <div class="container-x flex h-9 items-center justify-between text-[13px]">
    <a href={`mailto:${SITE.email}`} class="flex items-center gap-2 text-white/75 transition hover:text-white">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span class="hidden sm:inline">{SITE.email}</span>
      <span class="sm:hidden">Contact</span>
    </a>
    <div class="flex items-center gap-5 text-white/75">
      <a href="/updates" class="flex items-center gap-1.5 transition hover:text-white">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3v3M12 18v3M5 12H2M22 12h-3M5.6 5.6 7.7 7.7M16.3 16.3l2.1 2.1M18.4 5.6l-2.1 2.1M7.7 16.3l-2.1 2.1" stroke-linecap="round"/></svg>
        Updates
      </a>
      <a href="/support" class="flex items-center gap-1.5 transition hover:text-white">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M9.5 9a2.5 2.5 0 1 1 3.5 2.3c-.7.4-1 .8-1 1.7M12 17h.01" stroke-linecap="round"/></svg>
        Support
      </a>
    </div>
  </div>
</div>

<!-- Standaard, volledige-breedte navigatie -->
<header class="sticky top-0 z-50 border-b border-slate-100 bg-white/90 backdrop-blur-xl">
  <nav class="container-x flex h-16 items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2.5 text-[18px] font-extrabold text-ink">
      <Logo />
      <span>Rittenregistratie<span class="text-merk">.app</span></span>
    </a>

    <div class="hidden items-center gap-1 lg:flex">
      {
        NAV.map((item) => (
          <a
            href={item.href}
            class:list={[
              'rounded-lg px-3.5 py-2 text-[15px] font-semibold transition',
              pad === item.href ? 'text-merk' : 'text-slate-600 hover:text-ink',
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </div>

    <div class="flex items-center gap-2">
      <a href="/download" class="btn-primary !px-5 !py-2.5 text-sm">Download</a>
      <button id="menu-btn" class="grid h-10 w-10 place-items-center rounded-xl border border-slate-200 lg:hidden" aria-label="Menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"/></svg>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-slate-100 bg-white lg:hidden">
    <div class="container-x flex flex-col gap-1 py-4">
      {NAV.map((item) => (
        <a href={item.href} class="rounded-xl px-3 py-3 font-semibold text-slate-700 hover:bg-slate-100">{item.label}</a>
      ))}
      <a href="/contact" class="rounded-xl px-3 py-3 font-semibold text-slate-700 hover:bg-slate-100">Contact</a>
    </div>
  </div>
</header>

<script is:inline>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>

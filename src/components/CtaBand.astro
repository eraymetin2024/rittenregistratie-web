---
const {
  titel = 'Begin vandaag — gratis',
  tekst = 'Voldoe moeiteloos aan de Belastingdienst. Upgrade naar Premium voor volledige automatisering.',
} = Astro.props;
---
<section class="container-x my-24">
  <div
    data-reveal
    class="relative overflow-hidden rounded-[2rem] bg-gradient-to-br from-merk to-violet px-8 py-16 text-center shadow-glow sm:px-16"
  >
    <div class="grid-mask absolute inset-0 opacity-30"></div>
    <div class="relative">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl">{titel}</h2>
      <p class="mx-auto mt-4 max-w-xl text-white/85">{tekst}</p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="/download" class="btn bg-white text-merk hover:-translate-y-0.5">
          Download de app
        </a>
        <a href="/prijzen" class="btn border border-white/40 text-white hover:bg-white/10">
          Bekijk prijzen
        </a>
      </div>
    </div>
  </div>
</section>

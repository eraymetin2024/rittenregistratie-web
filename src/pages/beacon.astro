---
import Layout from '../layouts/Layout.astro';
import CtaBand from '../components/CtaBand.astro';
import { SITE, PRIJZEN } from '../consts';

const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: `${SITE.naam} iBeacon`,
  description:
    'Optioneel Bluetooth-baken (iBeacon) voor de auto. De telefoon herkent ' +
    'het baken automatisch en start je rit — ook op iPhone en ook als de app ' +
    'gesloten is. Jaren batterij, geen opladen, plug-and-play.',
  category: 'Bluetooth Low Energy beacon',
  brand: { '@type': 'Brand', name: SITE.naam },
  offers: {
    '@type': 'Offer',
    price: '17.95',
    priceCurrency: 'EUR',
    availability: 'https://schema.org/InStock',
    url: `${SITE.domein}/beacon`,
  },
};

const voordelen = [
  {
    titel: 'Meest betrouwbaar én precies',
    tekst:
      'Het baken zendt continu een uniek Bluetooth-signaal uit. Je telefoon ' +
      'herkent het zodra je instapt — geen gemiste ritten, geen valse starts ' +
      'door wandelingen of fietstochten.',
  },
  {
    titel: 'Jaren batterij, geen opladen',
    tekst:
      'Een knoopcelbatterij gaat jaren mee. Raakt hij ooit leeg? Dan vervang ' +
      'je hem zelf in tien seconden. Nooit een kabel of stopcontact nodig.',
  },
  {
    titel: 'Geen gedoe',
    tekst:
      'Eenmalig plaatsen en koppelen — daarna nooit meer naar omkijken. ' +
      'Geen handmatig starten, geen Bluetooth-koppeling met je auto nodig.',
  },
];

const vergelijking = [
  {
    aspect: 'Detectiemethode',
    zonder: 'Beweging + GPS van de telefoon',
    met: 'Vast Bluetooth-baken in de auto',
  },
  {
    aspect: 'Nauwkeurigheid',
    zonder: 'Goed, maar kan een wandeling of fiets soms als rit zien',
    met: 'Hoogste — herkent precies jouw auto',
  },
  {
    aspect: 'Op iPhone (app gesloten)',
    zonder: 'Beperkt door iOS-achtergrondregels',
    met: 'Werkt — iOS wekt de app voor een bekend baken',
  },
  {
    aspect: 'Batterijverbruik telefoon',
    zonder: 'Iets hoger door GPS/beweging',
    met: 'Laag — alleen kort Bluetooth scannen',
  },
  {
    aspect: 'Extra hardware',
    zonder: 'Geen',
    met: 'Eén klein baken (eenmalig)',
  },
];
---

<Layout
  title="iBeacon"
  description="De optionele iBeacon is een klein Bluetooth-baken voor in de auto. Je telefoon herkent het en start de rit automatisch — ook op iPhone en als de app gesloten is. Jaren batterij, geen opladen."
  jsonld={jsonld}
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="aurora absolute inset-0 -z-10"></div>
    <div class="container-x py-20 lg:py-24">
      <div class="grid items-center gap-12 lg:grid-cols-[1.1fr_1fr]">
        <div>
          <span class="eyebrow" data-reveal>iBeacon · optioneel</span>
          <h1
            data-reveal
            class="mt-5 text-4xl font-extrabold leading-[1.1] sm:text-5xl"
          >
            De meest betrouwbare manier om je
            <span class="gradient-text">rit automatisch</span> te starten
          </h1>
          <p data-reveal class="mt-5 max-w-xl text-lg text-zacht">
            De iBeacon is een klein Bluetooth-baken dat je in de auto legt. Je
            telefoon herkent het zodra je instapt en start de registratie
            vanzelf — ook op iPhone en ook als de app gesloten is.
          </p>
          <div data-reveal class="mt-8 flex flex-wrap gap-3">
            <a href={SITE.playUrl} class="btn-primary">Bekijk in de app</a>
            <a href="/prijzen" class="btn-ghost">Naar prijzen</a>
          </div>
        </div>

        <!-- Gradient baken-illustratie -->
        <div data-reveal class="flex justify-center" style="--reveal-delay:120ms">
          <svg
            viewBox="0 0 320 320"
            class="w-full max-w-sm"
            role="img"
            aria-label="iBeacon met Bluetooth-golven"
            xmlns="http://www.w3.org/2000/svg"
          >
            <defs>
              <radialGradient id="bk-glow" cx="50%" cy="42%" r="60%">
                <stop offset="0%" stop-color="#2F6BFF" stop-opacity="0.28" />
                <stop offset="100%" stop-color="#2F6BFF" stop-opacity="0" />
              </radialGradient>
              <linearGradient id="bk-body" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#2F6BFF" />
                <stop offset="100%" stop-color="#7C5CFC" />
              </linearGradient>
            </defs>

            <circle cx="160" cy="135" r="150" fill="url(#bk-glow)" />

            <!-- Concentrische BLE-golven -->
            <g
              fill="none"
              stroke="url(#bk-body)"
              stroke-linecap="round"
              stroke-width="3"
            >
              <path d="M118 135 a42 42 0 0 1 84 0" opacity="0.85" />
              <path d="M96 135 a64 64 0 0 1 128 0" opacity="0.55" />
              <path d="M74 135 a86 86 0 0 1 172 0" opacity="0.3" />
            </g>

            <!-- Baken-body -->
            <rect
              x="118"
              y="120"
              width="84"
              height="84"
              rx="26"
              fill="url(#bk-body)"
            />
            <rect
              x="118"
              y="120"
              width="84"
              height="84"
              rx="26"
              fill="#ffffff"
              opacity="0.06"
            />

            <!-- Bluetooth-glyph -->
            <path
              d="M150 138 l20 14 -14 10 v-32 l14 10 -20 14"
              fill="none"
              stroke="#ffffff"
              stroke-width="4"
              stroke-linecap="round"
              stroke-linejoin="round"
            />

            <!-- Pulserende stip -->
            <circle cx="160" cy="200" r="4" fill="#3FD0C9" />
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- Wat is het / hoe werkt het -->
  <section class="container-x py-24">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <span class="eyebrow">Wat is het</span>
      <h2 class="mt-4 text-3xl font-extrabold sm:text-4xl">
        Een baken dat je telefoon herkent
      </h2>
      <p class="mt-4 text-zacht">
        Geen abonnement op hardware, geen kabels, geen instellingen die je elke
        rit moet aanzetten. Je legt het baken eenmalig in de auto en koppelt het
        in de app — daarna gaat alles vanzelf.
      </p>
    </div>

    <div class="mx-auto mt-12 grid max-w-4xl gap-6 sm:grid-cols-3">
      <div class="card p-7" data-reveal>
        <span class="text-sm font-bold text-merk">Stap 1</span>
        <h3 class="mt-2 text-lg font-bold">Plaatsen</h3>
        <p class="mt-2 text-sm text-zacht">
          Leg het kleine baken in je auto — in het dashboardkastje of de
          middenconsole. Klaar.
        </p>
      </div>
      <div class="card p-7" data-reveal style="--reveal-delay:120ms">
        <span class="text-sm font-bold text-merk">Stap 2</span>
        <h3 class="mt-2 text-lg font-bold">Koppelen</h3>
        <p class="mt-2 text-sm text-zacht">
          Koppel het baken eenmalig aan je voertuig in de app. Plug-and-play, in
          minder dan een minuut.
        </p>
      </div>
      <div class="card p-7" data-reveal style="--reveal-delay:240ms">
        <span class="text-sm font-bold text-merk">Stap 3</span>
        <h3 class="mt-2 text-lg font-bold">Automatisch rijden</h3>
        <p class="mt-2 text-sm text-zacht">
          Stap je in, dan herkent je telefoon het baken en start de rit
          vanzelf. Ook op iPhone en als de app gesloten is.
        </p>
      </div>
    </div>

    <p class="mx-auto mt-10 max-w-2xl text-center text-sm text-zacht" data-reveal>
      Omdat iOS en Android een bekend Bluetooth-baken mogen herkennen — ook op de
      achtergrond — kan de app de registratie betrouwbaar starten zonder dat jij
      iets hoeft te doen.
    </p>
  </section>

  <!-- Voordelen -->
  <section class="container-x py-24">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <span class="eyebrow">Voordelen</span>
      <h2 class="mt-4 text-3xl font-extrabold sm:text-4xl">
        Waarom een iBeacon
      </h2>
    </div>

    <div class="mx-auto mt-12 grid max-w-4xl gap-6 sm:grid-cols-3">
      {
        voordelen.map((v, i) => (
          <div
            class="card p-7"
            data-reveal
            style={`--reveal-delay:${i * 120}ms`}
          >
            <h3 class="text-lg font-bold">{v.titel}</h3>
            <p class="mt-3 text-sm text-zacht">{v.tekst}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Vergelijking -->
  <section class="container-x py-24">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <span class="eyebrow">Vergelijking</span>
      <h2 class="mt-4 text-3xl font-extrabold sm:text-4xl">
        Zonder beacon vs. met beacon
      </h2>
      <p class="mt-4 text-zacht">
        Zonder baken werkt de detectie via beweging en GPS — prima voor de
        meeste mensen. Een baken voegt de hoogste betrouwbaarheid toe, vooral op
        iPhone.
      </p>
    </div>

    <div class="mx-auto mt-12 max-w-4xl" data-reveal>
      <div class="card overflow-hidden p-0">
        <div
          class="grid grid-cols-3 border-b border-ink/10 bg-mist px-6 py-4 text-sm font-bold"
        >
          <span></span>
          <span>Zonder beacon</span>
          <span class="text-merk">Met beacon</span>
        </div>
        {
          vergelijking.map((rij, i) => (
            <div
              class={`grid grid-cols-3 gap-4 px-6 py-4 text-sm ${
                i < vergelijking.length - 1 ? 'border-b border-ink/10' : ''
              }`}
            >
              <span class="font-semibold">{rij.aspect}</span>
              <span class="text-zacht">{rij.zonder}</span>
              <span class="font-medium">{rij.met}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Prijs -->
  <section class="container-x py-24">
    <div class="mx-auto max-w-4xl" data-reveal>
      <div class="card overflow-hidden p-8 sm:p-10">
        <div class="grid gap-8 lg:grid-cols-[1.4fr_1fr] lg:items-center">
          <div>
            <span class="eyebrow">Prijs</span>
            <h2 class="mt-4 text-2xl font-extrabold sm:text-3xl">
              Optioneel — en gratis bij een jaarabonnement
            </h2>
            <p class="mt-4 text-zacht">
              De iBeacon is volledig optioneel. Automatische rit-detectie werkt
              ook zonder, via GPS en auto-Bluetooth. Wil je de allerhoogste
              betrouwbaarheid — zeker op iPhone — dan schaf je het baken los aan.
            </p>
            <ul class="mt-6 space-y-2 text-sm text-zacht">
              <li>• Eenmalige aanschaf, geen abonnement op de hardware</li>
              <li>• Werkt op iOS én Android</li>
              <li>• Vervangbare batterij — geen opladen</li>
            </ul>
          </div>
          <div class="rounded-2xl bg-mist p-6 text-center">
            <p class="text-sm text-zacht">iBeacon</p>
            <p class="mt-2 text-4xl font-extrabold gradient-text">
              {PRIJZEN.beacon}
            </p>
            <p class="mt-2 text-sm text-zacht">eenmalig</p>
            <p
              class="mt-4 rounded-xl bg-groen/10 px-3 py-2 text-sm font-semibold text-groen"
            >
              Gratis bij een jaarabonnement
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBand />
</Layout>

---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../consts';

const kanalen = [
  { icon: 'mail', titel: 'E-mail', tekst: 'De snelste weg. We reageren meestal binnen 1 werkdag.', actie: `mailto:${SITE.email}`, knop: SITE.email },
  { icon: 'faq', titel: 'Veelgestelde vragen', tekst: 'Veel antwoorden vind je direct in onze uitgebreide FAQ.', actie: '/faq', knop: 'Bekijk de FAQ' },
  { icon: 'doc', titel: 'Aan de slag', tekst: 'Lees hoe je de app instelt en automatische detectie aanzet.', actie: '/hoe-het-werkt', knop: 'Hoe het werkt' },
];
const ic = {
  mail: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6" stroke-linecap="round"/></svg>',
  faq: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M9.5 9a2.5 2.5 0 1 1 3.5 2.3c-.7.4-1 .8-1 1.7M12 17h.01" stroke-linecap="round"/></svg>',
  doc: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 3h7l5 5v13H7z"/><path d="M14 3v5h5M9 13h6M9 17h6" stroke-linecap="round"/></svg>',
};
---
<Layout title="Support" description="Hulp nodig bij Rittenregistratie.app? Mail ons of bekijk de FAQ — we helpen je graag, meestal binnen 1 werkdag.">
  <section class="relative overflow-hidden">
    <div class="aurora absolute inset-0 -z-10"></div>
    <div class="container-x py-20 text-center lg:py-24">
      <h1 data-reveal class="text-4xl font-extrabold sm:text-5xl">Waarmee kunnen we <span class="gradient-text">helpen?</span></h1>
      <p data-reveal style="--reveal-delay:120ms" class="mx-auto mt-5 max-w-xl text-lg text-zacht">
        Een vraag, een probleem of een idee? We zijn een Nederlands team en denken graag met je mee.
      </p>
    </div>
  </section>

  <section class="container-x pb-24">
    <div class="grid gap-6 md:grid-cols-3">
      {kanalen.map((k, i) => (
        <div class="card flex flex-col" data-reveal style={`--reveal-delay:${i * 80}ms`}>
          <div class="grid h-12 w-12 place-items-center rounded-2xl bg-gradient-to-br from-merk to-violet text-white"><Fragment set:html={ic[k.icon]} /></div>
          <h2 class="mt-5 text-lg font-bold">{k.titel}</h2>
          <p class="mt-2 flex-1 text-[15px] leading-relaxed text-zacht">{k.tekst}</p>
          <a href={k.actie} class="btn-ghost mt-5 w-full">{k.knop}</a>
        </div>
      ))}
    </div>

    <div class="mx-auto mt-12 max-w-3xl rounded-3xl bg-mist p-8 text-center" data-reveal>
      <p class="text-zacht">Liever direct mailen?</p>
      <a href={`mailto:${SITE.email}`} class="mt-1 inline-block text-xl font-extrabold text-merk">{SITE.email}</a>
      <p class="mt-3 text-sm text-zacht">{SITE.bedrijf} · KvK {SITE.kvk} · Nederland</p>
    </div>
  </section>
</Layout>

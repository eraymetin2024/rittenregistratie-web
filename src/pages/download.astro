---
import Layout from '../layouts/Layout.astro';
import CtaBand from '../components/CtaBand.astro';
import { SITE } from '../consts';

const voordelen = [
  {
    titel: 'Gratis beginnen',
    tekst:
      'Houd je volledige, Belastingdienst-proof kilometeradministratie bij zonder een cent te betalen. Upgrade alleen wanneer je automatisering wilt.',
  },
  {
    titel: 'In een minuut klaar',
    tekst:
      'Download, maak een account aan en voeg je eerste voertuig toe. Je legt direct ritten vast met alle 8 verplichte velden.',
  },
  {
    titel: 'Privacy uit Nederland',
    tekst:
      'Gebouwd door Raysel Digital Solutions. Je gegevens staan veilig in de EU en worden nooit verkocht.',
  },
];
---

<Layout
  title="Download"
  description="Download Rittenregistratie.app voor Android en iOS. Begin gratis met je Belastingdienst-proof kilometeradministratie en upgrade wanneer je automatisering wilt."
>
  <section class="relative overflow-hidden">
    <div class="aurora absolute inset-0 -z-10"></div>
    <div class="container-x py-20 lg:py-24">
      <span class="eyebrow" data-reveal>Download</span>
      <h1
        data-reveal
        class="mt-5 text-4xl font-extrabold leading-[1.1] sm:text-5xl"
      >
        Download <span class="gradient-text">Rittenregistratie.app</span>
      </h1>
      <p data-reveal class="mt-5 max-w-xl text-lg text-zacht">
        Beschikbaar voor Android en iOS. Je begint volledig gratis — geen
        creditcard nodig. Upgrade naar Premium wanneer je automatische
        rit-detectie en cloud-back-up wilt.
      </p>

      <div class="mt-10 flex flex-wrap gap-4" data-reveal>
        <a
          href={SITE.playUrl}
          class="flex items-center gap-3 rounded-2xl bg-ink px-6 py-4 text-white shadow-lg transition hover:-translate-y-0.5"
        >
          <svg class="h-7 w-7 flex-none" viewBox="0 0 512 512" fill="currentColor" aria-hidden="true">
            <path d="M48 59.5v393c0 6.6 7.8 10.1 12.8 5.8l219.6-201.5L60.8 53.7C55.8 49.4 48 52.9 48 59.5z" opacity=".95"/>
            <path d="M361.8 207.1l-58.6-33.8-67.5 61.9 67.5 61.9 58.6-33.8c20.1-11.5 20.1-44.7 0-56.2z"/>
            <path d="M280.4 256.8L60.8 458.3c-3.3 2.9-7.9 2.4-10.6-.6l185.7-170.4 44.5-30.5z" opacity=".85"/>
            <path d="M280.4 256.8l-44.5-30.5L50.2 54.3c2.7-3 7.3-3.5 10.6-.6l219.6 203.1z" opacity=".7"/>
          </svg>
          <span class="text-left leading-tight">
            <span class="block text-xs text-white/70">Download in de</span>
            <span class="block text-lg font-bold">Google Play</span>
          </span>
        </a>

        <a
          href={SITE.appStoreUrl}
          class="flex items-center gap-3 rounded-2xl bg-ink px-6 py-4 text-white shadow-lg transition hover:-translate-y-0.5"
        >
          <svg class="h-7 w-7 flex-none" viewBox="0 0 384 512" fill="currentColor" aria-hidden="true">
            <path d="M318.7 268.7c-.2-37 16.6-64.9 50.5-85.5-19-27.1-47.5-42-85.2-44.9-35.7-2.8-74.7 20.8-89 20.8-15 0-49.5-19.8-76.5-19.8C61.3 140.6 0 184.2 0 273c0 26.2 4.8 53.3 14.4 81.2 12.8 36.7 58.9 126.6 107 125.1 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.5-90-57.5-91.3zM256.5 84c30.2-35.9 27.5-68.6 26.6-80.3-26.5 1.5-57.2 18.1-74.6 38.7-19.2 21.9-30.5 49-28.1 79.9 28.7 2.2 54.9-12.7 76.1-38.3z"/>
          </svg>
          <span class="text-left leading-tight">
            <span class="block text-xs text-white/70">Download in de</span>
            <span class="block text-lg font-bold">App Store</span>
          </span>
        </a>
      </div>

      <p data-reveal class="mt-6 text-sm text-zacht">
        Gratis te downloaden. Geen verplichtingen, geen advertenties.
      </p>
    </div>
  </section>

  <section class="container-x py-20 lg:py-24">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <span class="eyebrow">Waarom downloaden</span>
      <h2 class="mt-4 text-3xl font-extrabold sm:text-4xl">
        Snel starten, eerlijk geprijsd
      </h2>
    </div>

    <div class="mx-auto mt-12 grid max-w-5xl gap-6 sm:grid-cols-3">
      {
        voordelen.map((v, i) => (
          <div
            class="card p-8"
            data-reveal
            style={`--reveal-delay:${i * 100}ms`}
          >
            <h3 class="text-lg font-bold">{v.titel}</h3>
            <p class="mt-3 text-zacht">{v.tekst}</p>
          </div>
        ))
      }
    </div>
  </section>

  <CtaBand />
</Layout>
